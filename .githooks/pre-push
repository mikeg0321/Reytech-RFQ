#!/bin/bash
# Pre-push hook: runs critical tests before allowing push.
# Install: git config core.hooksPath .githooks
#
# This prevents pushing broken code. Pushes to main auto-deploy to production.
# Feature branches also get tested to catch issues before PR.

BRANCH=$(git branch --show-current)

echo "Pre-push gate: testing before push to '$BRANCH'..."
echo ""

# ── HARD BLOCK: Never push directly to main ─────────────────────────────────
# Main = production. Railway auto-deploys on push. ALL changes must go through
# a feature branch + PR + CI. No exceptions.

if [ "$BRANCH" = "main" ]; then
    echo ""
    echo "============================================================"
    echo "  PUSH BLOCKED: Direct pushes to main are not allowed."
    echo "============================================================"
    echo ""
    echo "  Main is production. Railway auto-deploys on push."
    echo "  All changes must go through a feature branch + PR + CI."
    echo ""
    echo "  Create a branch and use the ship workflow:"
    echo ""
    echo "    git checkout -b feat/my-feature"
    echo "    # <do work, commit>"
    echo "    make ship       # test + push + create PR"
    echo "    make promote    # merge after CI passes"
    echo ""
    echo "  For urgent hotfixes:"
    echo ""
    echo "    git checkout -b hotfix/fix-description"
    echo "    make ship"
    echo ""
    echo "============================================================"
    exit 1
fi

# ── Critical tests (always run, all branches) ───────────────────────────────
# These are the core business logic tests that must NEVER break.

echo "Running critical test suite..."
SECRET_KEY=test DASH_USER=test DASH_PASS=test FLASK_ENV=testing \
python -m pytest \
    tests/test_ams704_helpers.py \
    tests/test_template_registry.py \
    tests/test_pc_generation.py \
    tests/test_rfq_generation.py \
    tests/test_multipage_704.py \
    tests/test_compile_safety.py \
    tests/test_api_contracts.py \
    tests/test_pricing_math.py \
    tests/test_golden_path.py \
    tests/test_carrier_auto_status.py \
    tests/test_golden_path_pc_to_rfq_roundtrip.py \
    tests/test_email_pipeline_e2e.py \
    tests/test_profile_registry_manifest.py \
    tests/test_profile_contracts.py \
    -n auto -q --tb=short 2>&1

RESULT=$?

if [ $RESULT -ne 0 ]; then
    echo ""
    echo "PUSH BLOCKED: Critical tests failed."
    echo ""
    echo "Fix the failures above, then try again."
    echo "Run full suite for details: make test-full"
    exit 1
fi

# ── UI change gate: Chrome visual verification required ─────────────────────
# Memory: feedback_workflow_ui_chrome_verify — UI/UX changes MUST be exercised
# in Chrome DevTools MCP (not just template-render pytest). Backend tests +
# smoke + HTTP 200 don't prove the render, the JS, or the user-visible flow.
#
# Gate fires when the commits about to be pushed touch any UI file:
#   - src/templates/**/*.html
#   - src/static/** (*.js, *.css, etc.)
#   - Any other *.html or *.css in the tree
#
# To pass the gate, the pusher must provide evidence that Chrome-MCP verified
# the changes. Two equally-accepted proofs:
#
#   1. Set CHROME_VERIFIED=1 in the environment for the push.
#      Example: CHROME_VERIFIED=1 make ship auto=1
#
#   2. Add a `CHROME-VERIFIED:` footer to at least one of the commits being
#      pushed, describing what was visually confirmed. This preserves the
#      evidence in git history forever.
#      Example in the commit message body:
#        CHROME-VERIFIED: opened /rfq/<id>, opened Mark Sent modal, filled
#        sent_to + attachment, submitted, saw toast, reloaded, confirmed
#        lock banner + readonly dim on inputs.
#
# To skip the gate (rare — chore-only pushes, reverts, docs-only), set
# CHROME_VERIFIED_SKIP=1 with a short reason in the commit message.

UI_CHANGED=""
COMMIT_LOG=""

# Pick a comparison base. Prefer origin/<branch> (re-push to an existing
# feature branch); fall back to origin/main (first push of a feature
# branch that forked from main). We use this for both the stdin-driven
# and tty-driven invocations so new-branch first-pushes still get gated.
BASE_REF=""
if git rev-parse --verify "origin/$BRANCH" >/dev/null 2>&1; then
    BASE_REF="origin/$BRANCH"
elif git rev-parse --verify "origin/main" >/dev/null 2>&1; then
    BASE_REF="origin/main"
fi

# Try to read the push-plan lines git gives us on stdin. `read` with a
# 0.1s timeout lets us detect "stdin is empty pipe" without blocking the
# hook in direct-invocation scenarios (CI, manual test run).
STDIN_HAD_DATA=0
if [ ! -t 0 ]; then
    while IFS= read -r -t 0.5 LINE; do
        STDIN_HAD_DATA=1
        # shellcheck disable=SC2086
        set -- $LINE
        LOCAL_REF="${1:-}"; LOCAL_SHA="${2:-}"; REMOTE_REF="${3:-}"; REMOTE_SHA="${4:-}"
        if [ "$LOCAL_SHA" = "0000000000000000000000000000000000000000" ]; then
            continue  # branch deletion
        fi
        if [ -z "$REMOTE_SHA" ] || [ "$REMOTE_SHA" = "0000000000000000000000000000000000000000" ]; then
            # New remote branch — compare against origin/main if available.
            if [ -n "$BASE_REF" ]; then
                RANGE="$BASE_REF..$LOCAL_SHA"
            else
                RANGE="$LOCAL_SHA"
            fi
        else
            RANGE="$REMOTE_SHA..$LOCAL_SHA"
        fi
        UI_CHANGED="$UI_CHANGED
$(git diff --name-only "$RANGE" 2>/dev/null | \
          grep -E '^(src/templates/.*\.html$|src/static/.*$|.*\.css$|.*\.js$)' || true)"
        COMMIT_LOG="$COMMIT_LOG
$(git log --format=%B "$RANGE" 2>/dev/null || true)"
    done
fi

# If stdin gave us nothing (empty pipe or direct invocation), fall back
# to the base-ref diff so the gate still fires.
if [ "$STDIN_HAD_DATA" -eq 0 ] && [ -n "$BASE_REF" ]; then
    RANGE="$BASE_REF..HEAD"
    UI_CHANGED=$(git diff --name-only "$RANGE" 2>/dev/null | \
                 grep -E '^(src/templates/.*\.html$|src/static/.*$|.*\.css$|.*\.js$)' || true)
    COMMIT_LOG=$(git log --format=%B "$RANGE" 2>/dev/null || true)
fi

# Strip blank lines from UI_CHANGED so the empty-check below is reliable.
UI_CHANGED=$(echo "$UI_CHANGED" | sed '/^$/d')

if [ -n "$UI_CHANGED" ]; then
    # Evidence of Chrome verification:
    HAS_ENV_FLAG=0
    if [ "${CHROME_VERIFIED:-0}" = "1" ]; then HAS_ENV_FLAG=1; fi
    HAS_TRAILER=0
    if echo "$COMMIT_LOG" | grep -qiE '^CHROME[-_]VERIFIED:'; then HAS_TRAILER=1; fi
    HAS_SKIP=0
    if [ "${CHROME_VERIFIED_SKIP:-0}" = "1" ]; then HAS_SKIP=1; fi

    if [ $HAS_ENV_FLAG -eq 0 ] && [ $HAS_TRAILER -eq 0 ] && [ $HAS_SKIP -eq 0 ]; then
        echo ""
        echo "============================================================"
        echo "  PUSH BLOCKED: UI file(s) changed without Chrome-MCP proof"
        echo "============================================================"
        echo ""
        echo "  These files are in the push and need visual verification:"
        echo ""
        echo "$UI_CHANGED" | sed 's/^/    /'
        echo ""
        echo "  Per memory feedback_workflow_ui_chrome_verify, UI/UX"
        echo "  changes MUST be exercised in Chrome DevTools MCP — not"
        echo "  just pytest template-render checks. Screenshots + the"
        echo "  Claude visualizer should confirm each state:"
        echo "    - Empty state"
        echo "    - Filled state"
        echo "    - Error state"
        echo "    - Re-run / reload state"
        echo ""
        echo "  TWO WAYS TO PASS THE GATE:"
        echo ""
        echo "  1) Run Chrome-MCP verification, then push with the env flag:"
        echo ""
        echo "       CHROME_VERIFIED=1 make ship auto=1"
        echo ""
        echo "  2) Add a CHROME-VERIFIED: footer to the commit message"
        echo "     describing what you saw in Chrome. This preserves the"
        echo "     evidence in git history:"
        echo ""
        echo "       git commit --amend"
        echo "       # add to the body:"
        echo "       # CHROME-VERIFIED: opened /rfq/<id>, clicked Mark Sent,"
        echo "       # saw toast + reload + lock banner."
        echo ""
        echo "  RARE ESCAPE HATCH (chore/revert/docs only):"
        echo ""
        echo "       CHROME_VERIFIED_SKIP=1 make ship"
        echo ""
        echo "============================================================"
        exit 1
    fi

    if [ $HAS_ENV_FLAG -eq 1 ]; then
        echo "UI-change gate: CHROME_VERIFIED=1 env flag present — passing."
    elif [ $HAS_TRAILER -eq 1 ]; then
        echo "UI-change gate: CHROME-VERIFIED: commit trailer found — passing."
    elif [ $HAS_SKIP -eq 1 ]; then
        echo "UI-change gate: SKIP flag set — chore/revert/docs push; make"
        echo "sure to visually re-audit if anything user-facing shipped."
    fi
fi

# ── CANONICAL-STATE GATE (PR-1, 2026-05-02) ─────────────────────────────────
# Blocks new inline `WHERE status IN (...)`, `WHERE created_at >= ...`, and
# similar ad-hoc filters from landing outside `src/core/`. PR-1 put the
# canonical predicates in src/core/canonical_state.py with matching SQL VIEWs
# (v_active_queue_rfqs, v_real_sent, v_sourceable_pos, v_revenue_year_2026).
#
# Why this gate: home-page numbers diverged because every panel ran its own
# ad-hoc WHERE filter. New filters outside the truth layer reintroduce drift.
# Existing usages are NOT failed (would block every push); the ratchet only
# fires on new additions, so PR-2..PR-6 can migrate consumers incrementally.
#
# Override (rare, document the reason): CANONICAL_STATE_SKIP=1.

REMOTE_BRANCH_FOR_GATE="origin/main"
if git rev-parse "$REMOTE_BRANCH_FOR_GATE" >/dev/null 2>&1; then
    # New lines added vs main, restricted to source files OUTSIDE src/core/
    # (where canonical_state.py + migrations.py legitimately define filters)
    # and tests/ (where seed inserts use the columns).
    NEW_INLINE=$(git diff "$REMOTE_BRANCH_FOR_GATE...HEAD" -- \
        'src/' \
        ':(exclude)src/core/**' \
        ':(exclude)tests/**' 2>/dev/null \
      | grep -E '^\+[^+]' \
      | grep -viE '^\+\s*(#|//|\*|--|/\*)' \
      | grep -iE 'WHERE\s+(LOWER\()?(status|created_at|sent_at|invoice_date|logged_at)' \
      || true)

    # Apply allowlist (.canonical_allowlist.txt): full source lines that
    # we're explicitly grandfathering during the migration arc.
    if [ -f .canonical_allowlist.txt ] && [ -n "$NEW_INLINE" ]; then
        FILTERED=""
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            stripped=$(echo "$line" | sed 's/^+//')
            if ! grep -Fxq "$stripped" .canonical_allowlist.txt; then
                FILTERED="${FILTERED}${line}\n"
            fi
        done <<< "$NEW_INLINE"
        NEW_INLINE=$(printf "%b" "$FILTERED" | sed '/^$/d')
    fi

    if [ -n "$NEW_INLINE" ] && [ "${CANONICAL_STATE_SKIP:-0}" != "1" ]; then
        echo ""
        echo "============================================================"
        echo "  PUSH BLOCKED: new inline WHERE status / WHERE created_at /"
        echo "  sent_at / invoice_date / logged_at filter detected outside"
        echo "  src/core/ — these belong in src.core.canonical_state."
        echo "============================================================"
        echo ""
        echo "  Why this gate: home-page numbers diverged because every"
        echo "  panel ran its own ad-hoc filter. PR-1 (2026-05-02) put the"
        echo "  canonical predicates in src/core/canonical_state.py with"
        echo "  matching SQL VIEWs (v_active_queue_rfqs, v_real_sent,"
        echo "  v_sourceable_pos, v_revenue_year_2026). Use those instead."
        echo ""
        echo "  Offending new lines:"
        echo ""
        echo "$NEW_INLINE" | head -20 | sed 's/^/    /'
        echo ""
        echo "  Fix: replace the inline filter with a call to"
        echo "  is_active_queue() / is_real_sent() / is_sourceable_po() /"
        echo "  is_year_revenue() — or SELECT FROM the matching VIEW."
        echo ""
        echo "  ESCAPE HATCH (rare, document the reason):"
        echo "       CANONICAL_STATE_SKIP=1 make ship"
        echo ""
        echo "============================================================"
        exit 1
    fi

    if [ "${CANONICAL_STATE_SKIP:-0}" = "1" ]; then
        echo "Canonical-state gate: SKIP flag set — confirm no new ad-hoc filters."
    fi
fi

echo ""
echo "All pre-push checks passed."
exit 0
