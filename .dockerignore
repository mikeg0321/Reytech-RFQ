# Docker build context — exclude heavy runtime artifacts, keep seed data.
# data/ seed files (23MB) MUST stay in the image for _seed_volume() boot.
# Without seed data, the app crashes with FileNotFoundError on first boot.

# Heavy runtime-only artifacts (NOT in git, only exist on Railway volume)
data/email_corpus/
data/shadow_outputs/
data/pc_pdfs/
data/reytech.db
data/reytech.db-wal
data/reytech.db-shm
output/

# Backups live on the Railway volume under /data/backups — never needed in the
# image. Local dev accumulates 130MB+ here which otherwise bloats build upload.
# _seed_volume() (src/core/paths.py) only recurses into data/templates/, so
# excluding backups does not affect first-boot seeding.
data/backups/

# Git
.git/
.github/

# Python caches
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# IDE
.vscode/
.idea/
.claude/

# OS
.DS_Store
Thumbs.db

# Dev artifacts
_overnight_review/
_diag/
audit_screenshots/
tasks/
*.log

# Large docs not needed at runtime
OVERNIGHT_*.md
PRD-*.md
SESSION_RESUME.md
SHIP_IT.md
AUDIT.md
coveragerc
