<!DOCTYPE html>
<html><head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Agent Control Panel — Reytech</title>
<style>
:root { --bg:#0d1117; --sf:#161b22; --sf2:#21262d; --bd:#30363d; --tx:#e6edf3; --tx2:#8b949e;
  --ok:#238636; --warn:#d29922; --err:#da3633; --blue:#58a6ff; --purple:#bc8cff;
  --ac:#4f8cff; --ac2:#3b7cf5; --gn:#34d399; --rd:#f87171; --yl:#fbbf24; --or:#fb923c; --r:12px; }
* { box-sizing:border-box; margin:0; padding:0; }
body { font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; background:var(--bg); color:var(--tx); padding:16px; max-width:1000px; margin:auto; }
a { color:var(--blue); text-decoration:none; }
.agents-nav { display:flex; gap:8px; align-items:center; margin-bottom:20px; flex-wrap:wrap; }
.agents-nav a { padding:5px 12px; background:var(--sf2); border:1px solid var(--bd); border-radius:6px; font-size:13px; color:var(--tx); }
h1 { font-size:22px; margin-bottom:4px; }
.sub { color:var(--tx2); font-size:13px; margin-bottom:20px; }
.section { background:var(--sf); border:1px solid var(--bd); border-radius:10px; padding:16px; margin-bottom:16px; }
.section h2 { font-size:16px; margin-bottom:12px; display:flex; align-items:center; gap:8px; cursor:pointer; user-select:none; }
.section h2 .tag { font-size:11px; padding:2px 8px; border-radius:10px; font-weight:normal; }
.section h2 .caret { margin-left:auto; font-size:12px; color:var(--tx2); transition:transform .2s; }
.tag-ok { background:#238636; color:#fff; }
.tag-warn { background:#d29922; color:#000; }
.tag-off { background:var(--sf2); color:var(--tx2); border:1px solid var(--bd); }
.grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:10px; }
.btn { padding:10px 16px; border:1px solid var(--bd); border-radius:8px; background:var(--sf2); color:var(--tx);
  cursor:pointer; font-size:13px; text-align:left; transition:all 0.15s; display:flex; flex-direction:column; gap:4px; position:relative; }
.btn:hover { border-color:var(--blue); background:#1a2332; }
.btn:active { transform:scale(0.97); }
.btn:disabled { opacity:0.5; cursor:wait; }
.btn .label { font-weight:600; font-size:14px; }
.btn .desc { font-size:11px; color:var(--tx2); }
.btn-go { background:#1a3a5c; border-color:#2563eb; }
.btn-go:hover { background:#1e4a7c; }
.btn-danger { border-color:var(--err); }
.btn-danger:hover { background:#3a1515; }
.btn .spin { display:none; position:absolute; top:8px; right:8px; width:14px; height:14px; border:2px solid var(--bd); border-top-color:var(--blue); border-radius:50%; animation:sp .6s linear infinite; }
.btn.ld .spin { display:block; }
@keyframes sp { to { transform:rotate(360deg); } }
#result { background:#0a0e14; border:1px solid var(--bd); border-radius:8px; padding:16px; margin-top:16px;
  font-family:'SF Mono',Consolas,monospace; font-size:12px; line-height:1.6; white-space:pre-wrap;
  max-height:500px; overflow-y:auto; display:none; position:relative; }
#result .close { position:absolute; top:8px; right:12px; cursor:pointer; color:var(--tx2); font-size:16px; }
#result .close:hover { color:var(--tx); }
.fleet { display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:8px; margin-bottom:16px; }
.agent-card { padding:10px; border:1px solid var(--bd); border-radius:8px; background:var(--sf2); font-size:12px; }
.agent-card .name { font-weight:600; font-size:13px; margin-bottom:4px; }
.agent-card .mode { color:var(--tx2); }
.loading { color:var(--warn); }
.toast-c { position:fixed; top:16px; right:16px; z-index:9999; display:flex; flex-direction:column; gap:8px; max-width:380px; }
.toast { padding:12px 16px; border-radius:8px; font-size:13px; box-shadow:0 4px 16px rgba(0,0,0,.5); animation:si .3s ease; cursor:pointer; }
.t-ok { background:#1a3a2a; border:1px solid #238636; color:#7ee787; }
.t-err { background:#3a1515; border:1px solid #da3633; color:#f87171; }
.t-info { background:#1a2a3a; border:1px solid #2563eb; color:#79c0ff; }
@keyframes si { from { transform:translateX(100%); opacity:0; } to { transform:translateX(0); opacity:1; } }
.qa-bar { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px; padding:12px; background:var(--sf); border:1px solid var(--bd); border-radius:10px; }
.qa-btn { padding:8px 14px; background:var(--sf2); border:1px solid var(--bd); border-radius:8px; color:var(--tx); cursor:pointer; font-size:12px; font-weight:600; transition:all .15s; white-space:nowrap; }
.qa-btn:hover { border-color:var(--blue); background:#1a2332; }
.fin-cards { display:grid; grid-template-columns:repeat(auto-fill,minmax(130px,1fr)); gap:8px; margin-bottom:12px; }
.fin-c { background:var(--sf2); padding:10px; border-radius:8px; text-align:center; }
.fin-c .fl { font-size:9px; color:var(--tx2); text-transform:uppercase; letter-spacing:.5px; }
.fin-c .fv { font-size:16px; font-weight:700; margin-top:2px; }
.scol { transition:max-height .3s ease; overflow:hidden; }
.scol.hid { max-height:0 !important; }
.step-label { margin-bottom:8px;font-size:11px;font-weight:600;color:var(--tx2);text-transform:uppercase;letter-spacing:1px }
.env-box { margin-top:10px;padding:10px;background:#0a0e14;border-radius:8px;font-size:11px;font-family:monospace;color:#8b949e }
{{ brief_css|safe }}
</style>
</head><body>
<div class="agents-nav">
 <a href="/">🏠 Home</a> <a href="/quotes">📋 Quotes</a>
 <a href="/agents" style="border-color:var(--blue)">🤖 Agents</a>
 <a href="/growth-intel">📊 Growth Intel</a> <a href="/catalog">📦 Catalog</a>
</div>
<h1>🤖 Agent Control Panel</h1>
<div class="sub">Click any button to run it. Results + toasts appear inline. <span id="uptime" style="float:right;font-size:11px;color:var(--tx2)"></span></div>
<div class="toast-c" id="toasts"></div>

<!-- Quick Actions -->
<div class="qa-bar">
 <span style="color:var(--tx2);font-size:12px;padding:8px 0">⚡ Quick:</span>
 <button class="qa-btn" onclick="apiGet('/api/manager/brief')">📋 Daily Brief</button>
 <button class="qa-btn" onclick="apiGet('/api/qa/health')">🏥 Health</button>
 <button class="qa-btn" onclick="apiGet('/api/qb/financial-context')">💰 QB Snapshot</button>
 <button class="qa-btn" onclick="apiGet('/api/crm/activity?limit=10')">📋 Activity</button>
 <button class="qa-btn" onclick="apiGet('/api/price-alerts?limit=5')">🔔 Alerts</button>
 <button class="qa-btn" onclick="apiPost('/api/catalog/rebuild-from-history',{})">📦 Rebuild Catalog</button>
</div>

<!-- Fleet -->
<div id="fleet" class="section">
 <h2 onclick="tog('fleet')">Fleet Status <span class="tag tag-off" id="fleet-tag">loading...</span><span class="caret">▼</span></h2>
 <div class="scol" id="fleet-sc"><div class="fleet" id="fleet-grid"><div class="loading">Loading agent status...</div></div></div>
</div>

<!-- Workflow -->
<div class="section">
 <h2 onclick="tog('wf')">🔀 Workflow Orchestrator <span class="tag tag-ok">LangGraph</span><span class="caret">▼</span></h2>
 <div class="scol" id="wf-sc">
 <p style="color:#8b949e;font-size:12px;margin-bottom:10px">LangGraph-powered pipelines — chains agents into executable workflows.</p>
 <div class="grid">
  <button class="btn btn-go" onclick="ac(this,'/api/workflow/status')"><span class="label">📊 Orchestrator Status</span><span class="desc">Run history</span><span class="spin"></span></button>
  <button class="btn btn-go" onclick="runWorkflow('pc_pipeline')"><span class="label">⚡ PC Pipeline</span><span class="desc">SCPRS → Amazon → Price → 704</span><span class="spin"></span></button>
  <button class="btn btn-go" onclick="runWorkflow('lead_pipeline')"><span class="label">🎯 Lead Pipeline</span><span class="desc">Scan → Score → Draft → Approve</span><span class="spin"></span></button>
  <button class="btn btn-go" onclick="runWorkflow('quote_pipeline')"><span class="label">📋 Quote Pipeline</span><span class="desc">Quote PDF → Email → Review</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/workflow/graph/pc_pipeline')"><span class="label">🗺️ PC Graph</span><span class="desc">Node → edge</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/workflow/graph/lead_pipeline')"><span class="label">🗺️ Lead Graph</span><span class="desc">Node → edge</span><span class="spin"></span></button>
 </div></div>
</div>

<!-- Manager Brief -->
<div class="section">
 <h2 onclick="tog('brief')">🧠 Manager Brief <span class="tag tag-ok">Active</span><span class="caret">▼</span></h2>
 <div class="scol" id="brief-sc"><div class="grid">
  <button class="btn btn-go" onclick="ac(this,'/api/manager/brief')"><span class="label">📋 Daily Brief</span><span class="desc">What needs attention now</span><span class="spin"></span></button>
 </div></div>
</div>

<!-- Growth Engine -->
<div class="section">
 <h2 onclick="tog('growth')">🚀 Growth Engine <span class="tag tag-ok" id="growth-tag">v2.0</span><span class="caret">▼</span></h2>
 <div class="scol" id="growth-sc">
 <p style="color:#8b949e;font-size:12px;margin-bottom:8px">Proactive SCPRS-driven outreach — pull history → categorize → find buyers → email → voice follow-up.</p>
 <div class="step-label">Step 1 — Pull Reytech History</div>
 <div class="grid" style="margin-bottom:12px">
  <button class="btn btn-go" onclick="ac(this,'/api/growth/pull-history')"><span class="label">📥 Pull SCPRS History</span><span class="desc">All Reytech POs from 2022</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/growth/pull-status')"><span class="label">⏳ Pull Progress</span><span class="desc">Check scrape status</span><span class="spin"></span></button>
 </div>
 <div class="step-label">Step 2 — Find All Buyers</div>
 <div class="grid" style="margin-bottom:12px">
  <button class="btn btn-go" onclick="ac(this,'/api/growth/find-buyers')"><span class="label">🔍 Find Category Buyers</span><span class="desc">SCPRS buyer search</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/growth/buyer-status')"><span class="label">⏳ Buyer Progress</span><span class="desc">Buyer scrape status</span><span class="spin"></span></button>
 </div>
 <div class="step-label">Step 3 — Outreach</div>
 <div class="grid" style="margin-bottom:12px">
  <button class="btn btn-go" onclick="ac(this,'/api/growth/outreach?dry_run=true')"><span class="label">📧 Preview Outreach</span><span class="desc">Dry run</span><span class="spin"></span></button>
  <button class="btn" onclick="if(confirm('Send real emails?')) ac(this,'/api/growth/outreach?dry_run=false')" style="border-color:rgba(52,211,153,.3)"><span class="label">🚀 Send Outreach</span><span class="desc">Email all scored prospects</span><span class="spin"></span></button>
 </div>
 <div class="step-label">Step 4 — Follow Up</div>
 <div class="grid">
  <button class="btn" onclick="ac(this,'/api/growth/follow-ups')"><span class="label">📋 Follow-Up Queue</span><span class="desc">Non-responders 7d+</span><span class="spin"></span></button>
  <button class="btn" onclick="if(confirm('Auto-dial non-responders?')) ac(this,'/api/growth/voice-follow-up')"><span class="label">📞 Voice Follow-Up</span><span class="desc">AI call non-responders</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/growth/status')"><span class="label">📊 Growth Status</span><span class="desc">Engine dashboard</span><span class="spin"></span></button>
 </div></div>
</div>

<!-- Sales Intel -->
<div class="section">
 <h2 onclick="tog('intel')">🕵️ Sales Intel <span class="tag tag-ok">SCPRS</span><span class="caret">▼</span></h2>
 <div class="scol" id="intel-sc">
 <p style="color:#8b949e;font-size:12px;margin-bottom:10px">Territory intelligence — SCPRS procurement data, prospects, CRM push.</p>
 <div class="grid">
  <button class="btn btn-go" onclick="ac(this,'/api/intel/deep-pull')"><span class="label">🔍 Deep Pull</span><span class="desc">Full SCPRS scan</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/intel/pull-status')"><span class="label">⏳ Pull Status</span><span class="desc">Deep pull progress</span><span class="spin"></span></button>
  <button class="btn btn-go" onclick="ac(this,'/api/intel/priority-queue')"><span class="label">🎯 Priority Queue</span><span class="desc">Top-scored leads</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/intel/push-prospects?top=50')"><span class="label">📤 Push Prospects</span><span class="desc">Top 50 → CRM</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/intel/sb-admin-match')"><span class="label">🏢 SB Admin Match</span><span class="desc">Small business contacts</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/intel/revenue')"><span class="label">💰 Revenue Intel</span><span class="desc">By institution</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/intel/status')"><span class="label">📊 Intel Status</span><span class="desc">Engine dashboard</span><span class="spin"></span></button>
 </div></div>
</div>

<!-- CS Agent -->
<div class="section">
 <h2 onclick="tog('cs')">📧 CS Agent <span class="tag tag-off" id="cs-badge">loading...</span><span class="caret">▼</span></h2>
 <div class="scol" id="cs-sc">
 <div id="cs-drafts-preview" style="margin-bottom:12px"></div>
 <div class="grid">
  <button class="btn btn-go" onclick="location.href='/outbox'" style="border-color:rgba(251,191,36,.4)"><span class="label">📬 Email Outbox</span><span class="desc">Review AI drafts</span></button>
  <button class="btn" onclick="ap(this,'/api/cs/classify',{})" style="border-color:rgba(251,191,36,.4)"><span class="label">🤖 Classify Inbox</span><span class="desc">Run AI classifier</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/cs/status')"><span class="label">📊 CS Status</span><span class="desc">Agent health</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/cs/drafts')"><span class="label">📝 View Drafts</span><span class="desc">Pending AI drafts</span><span class="spin"></span></button>
 </div></div>
</div>

<!-- Workflow Tester -->
<div class="section">
 <h2 onclick="tog('wft')">🧪 Workflow Tester <span class="tag tag-off" id="wf-badge">loading...</span><span class="caret">▼</span></h2>
 <div class="scol" id="wft-sc">
 <div id="wf-latest-preview" style="margin-bottom:12px"></div>
 <div class="grid">
  <button class="btn btn-go" onclick="location.href='/qa/workflow'" style="border-color:rgba(79,140,255,.4)"><span class="label">📋 Full Report</span><span class="desc">Detailed results</span></button>
  <button class="btn" onclick="runWorkflowTests()" id="wf-run-btn" style="border-color:rgba(79,140,255,.4)"><span class="label">▶ Run Now</span><span class="desc">Execute all tests</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/qa/health')"><span class="label">🏥 Health</span><span class="desc">Quick check</span><span class="spin"></span></button>
  <button class="btn" onclick="location.href='/qa/intelligence'"><span class="label">🧠 QA Intel</span><span class="desc">AI diagnostics</span></button>
 </div></div>
</div>

<!-- Outbox -->
<div class="section">
 <h2 onclick="tog('outbox')">📤 Outbox & Email <span class="tag tag-ok">Active</span><span class="caret">▼</span></h2>
 <div class="scol" id="outbox-sc"><div class="grid">
  <button class="btn btn-go" onclick="ac(this,'/api/outbox')"><span class="label">📤 All Outbox</span><span class="desc">Queued emails</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/outbox?status=draft')"><span class="label">📝 Drafts</span><span class="desc">Pending review</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/outbox/sent')"><span class="label">✅ Sent</span><span class="desc">Already sent</span><span class="spin"></span></button>
  <button class="btn btn-go" onclick="draftForPc()"><span class="label">✏️ Draft for PC</span><span class="desc">Create from PC</span><span class="spin"></span></button>
  <button class="btn btn-danger" onclick="sendApproved()"><span class="label">🚀 Send Approved</span><span class="desc">Send all approved</span><span class="spin"></span></button>
 </div></div>
</div>

<!-- Leads -->
<div class="section">
 <h2 onclick="tog('leads')">🎯 Lead Management <span class="tag tag-ok">Active</span><span class="caret">▼</span></h2>
 <div class="scol" id="leads-sc"><div class="grid">
  <button class="btn btn-go" onclick="ac(this,'/api/leads')"><span class="label">📋 All Leads</span><span class="desc">Full list</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/leads?status=new')"><span class="label">🆕 New Leads</span><span class="desc">Unprocessed</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/leads/analytics')"><span class="label">📊 Lead Analytics</span><span class="desc">Conversion funnel</span><span class="spin"></span></button>
 </div></div>
</div>

<!-- Email Scanner -->
<div class="section">
 <h2 onclick="tog('scanner')">📡 Email Scanner <span class="tag tag-ok">Active</span><span class="caret">▼</span></h2>
 <div class="scol" id="scanner-sc"><div class="grid">
  <button class="btn" onclick="ac(this,'/api/scanner/status')"><span class="label">📊 Status</span><span class="desc">Current state</span><span class="spin"></span></button>
  <button class="btn btn-go" onclick="ap(this,'/api/scanner/start',{interval:120})"><span class="label">▶ Start</span><span class="desc">Poll every 2 min</span><span class="spin"></span></button>
  <button class="btn btn-danger" onclick="ap(this,'/api/scanner/stop')"><span class="label">⏹ Stop</span><span class="desc">Pause polling</span><span class="spin"></span></button>
  <button class="btn" onclick="ap(this,'/api/scanner/scan')"><span class="label">🔄 Scan Now</span><span class="desc">One-time check</span><span class="spin"></span></button>
 </div></div>
</div>

<!-- Item ID -->
<div class="section">
 <h2 onclick="tog('itemid')">🔬 Item Identification <span class="tag tag-ok">Active</span><span class="caret">▼</span></h2>
 <div class="scol" id="itemid-sc"><div class="grid">
  <button class="btn btn-go" onclick="identifyItem()"><span class="label">🔍 Identify Item</span><span class="desc">Describe → find product</span><span class="spin"></span></button>
  <button class="btn" onclick="identifyPc()"><span class="label">📋 ID All PC Items</span><span class="desc">Identify all in a PC</span><span class="spin"></span></button>
 </div></div>
</div>

<!-- Voice -->
<div class="section">
 <h2 onclick="tog('voice')">📞 Voice AI <span class="tag tag-off" id="voice-tag">not configured</span><span class="caret">▼</span></h2>
 <div class="scol" id="voice-sc">
 <div class="grid">
  <button class="btn btn-go" onclick="ac(this,'/api/voice/status')"><span class="label">📊 Voice Status</span><span class="desc">Vapi/Twilio health</span><span class="spin"></span></button>
  <button class="btn btn-go" onclick="ac(this,'/api/voice/verify')"><span class="label">✅ Verify Config</span><span class="desc">Test API keys</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/voice/scripts')"><span class="label">📜 Scripts</span><span class="desc">Call scripts</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/voice/log')"><span class="label">📋 Call Log</span><span class="desc">Recent calls</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/voice/vapi-calls')"><span class="label">📞 Vapi Calls</span><span class="desc">Vapi history</span><span class="spin"></span></button>
  <button class="btn btn-go" onclick="testCall()"><span class="label">🧪 Test Call</span><span class="desc">Make a test call</span><span class="spin"></span></button>
  <button class="btn" onclick="importTwilio()"><span class="label">📱 Import Twilio #</span><span class="desc">Reytech caller ID</span><span class="spin"></span></button>
 </div>
 <div class="env-box">
  <div style="color:var(--warn);margin-bottom:4px">Railway env vars:</div>
  <div>VAPI_API_KEY=... <span style="color:#3fb950">(required)</span></div>
  <div>TWILIO_ACCOUNT_SID=AC... <span style="color:#8b949e">(optional)</span></div>
  <div>TWILIO_AUTH_TOKEN=... <span style="color:#8b949e">(optional)</span></div>
  <div>TWILIO_PHONE_NUMBER=+1... <span style="color:#8b949e">(optional)</span></div>
 </div></div>
</div>

<!-- QuickBooks — ENHANCED -->
<div class="section" id="qb-section">
 <h2 onclick="tog('qb')">🧾 QuickBooks Online <span class="tag tag-off" id="qb-tag">not connected</span><span class="caret">▼</span></h2>
 <div class="scol" id="qb-sc">
 <p style="color:#8b949e;font-size:12px;margin-bottom:10px">Full financial context — invoices, customers, vendors, AR. All agents use this data.</p>
 <div id="qb-finance" class="fin-cards" style="display:none"></div>
 <div class="step-label">Connection</div>
 <div class="grid" style="margin-bottom:12px">
  <button class="btn btn-go" onclick="window.location='/api/qb/connect'"><span class="label">🔗 Connect QuickBooks</span><span class="desc">Start OAuth2 flow</span></button>
  <button class="btn btn-go" onclick="ac(this,'/api/qb/diagnose')"><span class="label">🔧 Diagnose</span><span class="desc">Full diagnostic trace</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/qb/company')"><span class="label">🏢 Company Info</span><span class="desc">Verify connected company</span><span class="spin"></span></button>
 </div>
 <div class="step-label">Financial Reports</div>
 <div class="grid" style="margin-bottom:12px">
  <button class="btn" onclick="ac(this,'/api/qb/financial-context')"><span class="label">📊 Financial Snapshot</span><span class="desc">Full context</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/qb/pnl')"><span class="label">📈 Profit & Loss</span><span class="desc">YTD income</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/qb/aging')"><span class="label">📊 AR Aging</span><span class="desc">Receivables by age</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/qb/invoices/summary')"><span class="label">📋 Invoice Summary</span><span class="desc">Open/overdue/paid</span><span class="spin"></span></button>
 </div>
 <div class="step-label">Data</div>
 <div class="grid">
  <button class="btn" onclick="ac(this,'/api/qb/invoices?status=open')"><span class="label">💰 Open Invoices</span><span class="desc">Unpaid</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/qb/invoices?status=overdue')"><span class="label">⚠️ Overdue</span><span class="desc">Past-due</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/qb/payments')"><span class="label">💵 Recent Payments</span><span class="desc">Last 30 days</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/qb/customers')"><span class="label">👤 Customers</span><span class="desc">QB list</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/qb/customers/balances')"><span class="label">💳 AR Balances</span><span class="desc">Top receivables</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/qb/vendors')"><span class="label">👥 Vendors</span><span class="desc">Pull vendor list</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/qb/pos')"><span class="label">📄 Recent POs</span><span class="desc">Last 30 days</span><span class="spin"></span></button>
 </div>
 <div class="env-box">
  <div style="color:var(--warn);margin-bottom:4px">Railway env vars needed:</div>
  <div>QB_CLIENT_ID=... &nbsp; QB_CLIENT_SECRET=...</div>
  <div>QB_REALM_ID=... (auto on connect) &nbsp; QB_REFRESH_TOKEN=... (auto on connect)</div>
 </div></div>
</div>

<!-- CRM Activity -->
<div class="section">
 <h2 onclick="tog('crm')">📋 CRM Activity <span class="tag tag-ok">Phase 16</span><span class="caret">▼</span></h2>
 <div class="scol" id="crm-sc">
 <div class="grid">
  <button class="btn btn-go" onclick="ac(this,'/api/crm/activity?limit=20')"><span class="label">📋 Recent Activity</span><span class="desc">Last 20 events</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/crm/agency/CDCR')"><span class="label">🏢 CDCR Intel</span><span class="desc">Agency summary</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/crm/agency/CCHCS')"><span class="label">🏥 CCHCS Intel</span><span class="desc">Agency summary</span><span class="spin"></span></button>
 </div></div>
</div>

<!-- Predictive Intel -->
<div class="section">
 <h2 onclick="tog('pred')">🎯 Predictive Intel <span class="tag tag-ok">Phase 19</span><span class="caret">▼</span></h2>
 <div class="scol" id="pred-sc">
 <div class="grid">
  <button class="btn btn-go" onclick="predictWin()"><span class="label">🎯 Predict Win</span><span class="desc">Score opportunity</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/intel/competitors')"><span class="label">🕵️ Competitor Intel</span><span class="desc">Lost patterns</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/intel/competitors?institution=CSP-Sacramento')"><span class="label">🏢 CSP Intel</span><span class="desc">Sacramento competitors</span><span class="spin"></span></button>
  <button class="btn" onclick="testShipping()"><span class="label">📦 Test Shipping</span><span class="desc">Detect tracking</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/win-loss-analytics')"><span class="label">📊 Win/Loss</span><span class="desc">Outcome patterns</span><span class="spin"></span></button>
 </div></div>
</div>

<!-- QA Agent -->
<div class="section">
 <h2 onclick="tog('qa')">🔍 QA Agent <span class="tag tag-ok" id="qa-tag">Active</span><span class="caret">▼</span></h2>
 <div class="scol" id="qa-sc">
 <div class="grid">
  <button class="btn btn-go" onclick="ac(this,'/api/qa/health')"><span class="label">🏥 Health Check</span><span class="desc">Full system</span><span class="spin"></span></button>
  <button class="btn btn-go" onclick="ac(this,'/api/qa/health?checks=sales')"><span class="label">💰 Sales QA</span><span class="desc">Quote totals, $2M goal</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/qa/scan')"><span class="label">🔍 Code Scan</span><span class="desc">JS/HTML/Python quality</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/qa/history')"><span class="label">📊 History</span><span class="desc">Past reports</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/qa/trend')"><span class="label">📈 Trend</span><span class="desc">Score over time</span><span class="spin"></span></button>
 </div></div>
</div>

<!-- Testing -->
<div class="section">
 <h2 onclick="tog('test')">🧪 Testing <span class="tag tag-warn">Sandbox</span><span class="caret">▼</span></h2>
 <div class="scol" id="test-sc">
 <div class="grid">
  <button class="btn btn-go" onclick="ac(this,'/api/test/create-pc')"><span class="label">📝 Create Test RFQ</span><span class="desc">CSP-Sacramento test</span><span class="spin"></span></button>
  <button class="btn" onclick="ac(this,'/api/test/status')"><span class="label">📊 Test Status</span><span class="desc">Active test records</span><span class="spin"></span></button>
  <button class="btn" onclick="if(confirm('Remove all test data?')) ac(this,'/api/test/cleanup?reset_counter=false')" style="border-color:rgba(248,113,113,.3)"><span class="label">🗑️ Clean Test Data</span><span class="desc">Remove TEST records</span><span class="spin"></span></button>
 </div></div>
</div>

<div id="result"><span class="close" onclick="closeResult()">✕</span><pre id="result-content"></pre></div>

<script>
var R=document.getElementById('result'),RC=document.getElementById('result-content'),_ab=null,_plt=Date.now();

function showResult(d){RC.textContent=typeof d==='string'?d:JSON.stringify(d,null,2);R.style.display='block';R.scrollIntoView({behavior:'smooth',block:'nearest'});if(_ab){_ab.classList.remove('ld');_ab.disabled=false;_ab=null;}}
function closeResult(){R.style.display='none';}

function toast(m,t){var c=document.getElementById('toasts'),d=document.createElement('div');d.className='toast t-'+(t||'info');d.textContent=m;d.onclick=function(){d.remove();};c.appendChild(d);setTimeout(function(){if(d.parentNode)d.remove();},5000);}

function _hr(r){
  if(!r.ok){
    if(r.status===401){toast('Auth required — reload page','err');return Promise.reject('401');}
    return r.text().then(function(t){try{return JSON.parse(t);}catch(e){toast('Error '+r.status,'err');return{ok:false,error:'HTTP '+r.status+': '+t.substring(0,200)};}});
  }
  return r.json();
}

function apiGet(u){RC.textContent='Loading...';R.style.display='block';fetch(u,{credentials:'same-origin'}).then(_hr).then(function(d){if(d&&d.ok===false&&d.error)toast(d.error,'err');else if(d&&d.ok!==false)toast('✅ Done','ok');showResult(d);}).catch(function(e){showResult('Error: '+e);});}

function apiPost(u,b){RC.textContent='Loading...';R.style.display='block';fetch(u,{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/json'},body:b?JSON.stringify(b):'{}'}).then(_hr).then(function(d){if(d&&d.ok===false&&d.error)toast(d.error,'err');else if(d&&d.ok!==false)toast('✅ Done','ok');showResult(d);}).catch(function(e){showResult('Error: '+e);});}

function ac(btn,u){if(btn){btn.classList.add('ld');btn.disabled=true;_ab=btn;}apiGet(u);}
function ap(btn,u,b){if(btn){btn.classList.add('ld');btn.disabled=true;_ab=btn;}apiPost(u,b);}

// Section collapse (persisted)
var _col=JSON.parse(localStorage.getItem('agCol')||'{}');
function tog(id){var el=document.getElementById(id+'-sc');if(!el)return;var h=el.classList.toggle('hid');_col[id]=h;localStorage.setItem('agCol',JSON.stringify(_col));var i=el.parentElement.querySelector('.caret');if(i)i.style.transform=h?'rotate(-90deg)':'';}
Object.keys(_col).forEach(function(id){if(_col[id]){var el=document.getElementById(id+'-sc');if(el){el.classList.add('hid');var i=el.parentElement.querySelector('.caret');if(i)i.style.transform='rotate(-90deg)';}}});

// CS drafts
fetch('/api/cs/drafts',{credentials:'same-origin'}).then(_hr).then(function(d){
  var b=document.getElementById('cs-badge'),p=document.getElementById('cs-drafts-preview'),dr=Array.isArray(d.drafts)?d.drafts:(d.cs_drafts||[]);
  if(b){if(dr.length>0){b.textContent=dr.length+' draft'+(dr.length>1?'s':'');b.className='tag tag-warn';}else{b.textContent='inbox clear';b.className='tag tag-ok';}}
  if(p&&dr.length>0){p.innerHTML=dr.slice(0,3).map(function(x){var m={};try{m=JSON.parse(x.metadata||'{}')}catch(e){}var f=m.original_sender||x.to||'?',s=m.original_subject||x.subject||'Email';return '<div style="background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.25);border-radius:8px;padding:10px 12px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;gap:10px"><div><div style="font-size:12px;font-weight:600;color:#fbbf24">📬 '+s+'</div><div style="font-size:11px;color:#8b949e;margin-top:2px">From: '+f+'</div></div><a href="/outbox" style="font-size:12px;font-weight:600;color:#fbbf24;white-space:nowrap;border:1px solid rgba(251,191,36,.4);padding:4px 10px;border-radius:6px;background:rgba(251,191,36,.1)">Review →</a></div>';}).join('');}
}).catch(function(){var b=document.getElementById('cs-badge');if(b){b.textContent='unavailable';b.className='tag tag-off';}});

// Workflow tester
fetch('/api/qa/workflow/latest',{credentials:'same-origin'}).then(_hr).then(function(d){
  var b=document.getElementById('wf-badge'),p=document.getElementById('wf-latest-preview');
  if(!d||!d.score){if(b)b.textContent='no runs yet';return;}
  var sc=d.score||0,col=sc>=90?'#34d399':sc>=70?'#fbbf24':'#f87171',bg=sc>=90?'rgba(52,211,153,.15)':sc>=70?'rgba(251,191,36,.15)':'rgba(248,113,113,.15)';
  if(b){b.textContent=sc+'/100 '+d.grade;b.style.background=bg;b.style.color=col;}
  if(p&&d.full_report){var fr=d.full_report,fails=(fr.critical_failures||[]),warns=(fr.results||[]).filter(function(r){return r.status==='warn';});
    if(fails.length+warns.length>0){p.innerHTML=(fails.concat(warns)).slice(0,3).map(function(r){var ic=r.status==='fail'?'❌':'⚠️';return '<div style="background:rgba('+(r.status==='fail'?'248,113,113':'251,191,36')+', .08);border:1px solid rgba('+(r.status==='fail'?'248,113,113':'251,191,36')+', .25);border-radius:8px;padding:8px 12px;margin-bottom:6px;font-size:12px">'+ic+' <b>'+r.test+'</b>: '+r.message+(r.fix?'<div style="color:#fbbf24;font-size:11px;margin-top:3px">💡 '+r.fix+'</div>':'')+'</div>';}).join('');}
    else{p.innerHTML='<div style="color:#34d399;font-size:12px;padding:8px">✅ All tests passing</div>';}}
}).catch(function(){var b=document.getElementById('wf-badge');if(b){b.textContent='unavailable';b.style.color='var(--tx2)';}});

function runWorkflowTests(){var btn=document.getElementById('wf-run-btn');if(btn){btn.disabled=true;btn.querySelector('.label').textContent='⏳ Running…';btn.classList.add('ld');}fetch('/api/qa/workflow',{method:'POST',credentials:'same-origin'}).then(_hr).then(function(d){var sc=d.score||0,col=sc>=90?'#34d399':sc>=70?'#fbbf24':'#f87171',bg=sc>=90?'rgba(52,211,153,.15)':sc>=70?'rgba(251,191,36,.15)':'rgba(248,113,113,.15)',b=document.getElementById('wf-badge');if(b){b.textContent=sc+'/100 '+d.grade;b.style.background=bg;b.style.color=col;}if(btn){btn.disabled=false;btn.querySelector('.label').textContent='▶ Run Now';btn.classList.remove('ld');}toast('Tests: '+sc+'/100 '+d.grade,sc>=70?'ok':'err');location.href='/qa/workflow';}).catch(function(){if(btn){btn.disabled=false;btn.querySelector('.label').textContent='▶ Run Now';btn.classList.remove('ld');}});}

// Prompt functions
function runWorkflow(n){var i={};if(n==='pc_pipeline'){var p=prompt('Price Check ID (e.g. pc_abc123):');if(!p)return;i={pc_id:p};}else if(n==='quote_pipeline'){var p=prompt('Price Check ID for quote:');if(!p)return;i={pc_id:p};}apiPost('/api/workflow/run',{workflow:n,inputs:i});}
function draftForPc(){var p=prompt('Price Check ID:');if(!p)return;var q=prompt('Quote number:','');apiPost('/api/outbox/draft/pc/'+p,{quote_number:q||''});}
function identifyItem(){var d=prompt('Item description:');if(!d)return;apiPost('/api/identify',{description:d});}
function identifyPc(){var p=prompt('Price Check ID:');if(!p)return;apiGet('/api/identify/pc/'+p);}
function sendApproved(){if(!confirm('Send ALL approved emails?'))return;apiPost('/api/outbox/send-approved');}
function testCall(){var p=prompt('Phone (E.164):');if(!p)return;var s=prompt('Script:','lead_intro')||'lead_intro';apiPost('/api/voice/call',{phone:p,script:s,variables:{po_number:'PO-TEST',institution:'CSP-Sacramento',quote_number:'R26Q1'}});}
function importTwilio(){if(!confirm('Import Twilio number into Vapi?'))return;apiPost('/api/voice/import-twilio',{});}
function predictWin(){var i=prompt('Institution:');if(!i)return;var a=prompt('Agency:','')||'',v=prompt('PO value ($):','5000')||'0';apiGet('/api/predict/win?institution='+encodeURIComponent(i)+'&agency='+encodeURIComponent(a)+'&value='+v);}
function testShipping(){var s=prompt('Email subject:','Your Amazon order has shipped');if(!s)return;var b=prompt('Email body:','Tracking: TBA123456789012. Delivery: Feb 20.');apiPost('/api/shipping/scan-email',{subject:s,body:b,sender:'ship-confirm@amazon.com'});}

// Fleet load + auto-refresh
function loadFleet(){
  fetch('/api/agents/status',{credentials:'same-origin'}).then(_hr).then(function(data){
    var grid=document.getElementById('fleet-grid'),tag=document.getElementById('fleet-tag');
    if(!data.ok){grid.innerHTML='<div>Failed to load</div>';return;}
    tag.textContent=data.active+'/'+data.total+' active';tag.className='tag '+(data.active>5?'tag-ok':'tag-warn');
    var html='';for(var name in data.agents){var info=data.agents[name],isOff=info.status==='not_available',mode=info.mode||info.status||(info.configured===false?'not configured':'ready'),dot=isOff?'⚫':(info.configured===false||info.api_key_set===false?'🟡':'🟢');html+='<div class="agent-card"><div class="name">'+dot+' '+name.replace(/_/g,' ')+'</div><div class="mode">'+mode+'</div></div>';}
    grid.innerHTML=html;
    var vt=document.getElementById('voice-tag'),voice=data.agents.voice_calls||{};
    if(voice.vapi_configured){vt.textContent='Vapi AI';vt.className='tag tag-ok';}else if(voice.twilio_configured){vt.textContent='Twilio TTS';vt.className='tag tag-warn';}else if(voice.status!=='not_available'){vt.textContent='needs setup';vt.className='tag tag-warn';}
    var qt=document.getElementById('qb-tag'),qb=data.agents.quickbooks||{};
    if(qb.has_valid_token){qt.textContent='connected';qt.className='tag tag-ok';}else if(qb.configured){qt.textContent='token expired';qt.className='tag tag-warn';}else if(qb.status!=='not_available'){qt.textContent='not connected';qt.className='tag tag-warn';}
    var qaInfo=data.agents.qa||{},qaTag=document.getElementById('qa-tag');
    if(qaInfo.last_grade&&qaInfo.last_grade!=='—'){var gC={'A':'tag-ok','B':'tag-ok','C':'tag-warn','D':'tag-warn','F':'tag-off'}[qaInfo.last_grade]||'tag-warn';qaTag.textContent='Grade: '+qaInfo.last_grade+' ('+qaInfo.last_score+')';qaTag.className='tag '+gC;}
    if(qb.has_valid_token)loadQBFinance();
  }).catch(function(){document.getElementById('fleet-grid').innerHTML='<div>Failed to load</div>';});
}
function loadQBFinance(){
  fetch('/api/qb/financial-context',{credentials:'same-origin'}).then(_hr).then(function(fc){
    if(!fc.ok)return;var el=document.getElementById('qb-finance');el.style.display='grid';
    function mk(l,v,c){return '<div class="fin-c"><div class="fl">'+l+'</div><div class="fv" style="color:'+(c||'var(--tx)')+'">'+v+'</div></div>';}
    el.innerHTML=mk('Receivable','$'+(fc.total_receivable||0).toLocaleString(),'var(--yl)')+mk('Overdue','$'+(fc.overdue_amount||0).toLocaleString(),'var(--rd)')+mk('Collected','$'+(fc.total_collected||0).toLocaleString(),'var(--gn)')+mk('Open Inv',fc.open_invoices||0,'var(--ac)')+mk('Customers',fc.customer_count||0,'var(--purple)')+mk('Vendors',fc.vendor_count||0,'var(--tx)');
  }).catch(function(){});
}
loadFleet();setInterval(loadFleet,60000);
setInterval(function(){var s=Math.floor((Date.now()-_plt)/1000),m=Math.floor(s/60),el=document.getElementById('uptime');if(el)el.textContent='Page: '+(m>0?m+'m ':'')+s%60+'s';},1000);
</script>
{{ brief_html|safe }}
<script>{{ brief_js|safe }}</script>
</body></html>
