# Prevent binary files from bloating diffs
*.db binary -diff
*.db-wal binary -diff
*.db-shm binary -diff
*.pdf binary -diff
*.png binary -diff
*.jpg binary -diff
*.jpeg binary -diff

# Ensure consistent line endings
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.sh text eol=lf
