# Reytech RFQ — Environment Variables
# Copy to .env and fill in values (or set in Railway dashboard)

# ── Required ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-flask-secret-key
DASH_USER=reytech
DASH_PASS=your-dashboard-password

# ── API Key (for MCP, webhooks, service-to-service) ──────────────────────────
API_KEY=your-secret-key-here

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_SERVER_NAME=reytech-rfq
MCP_SERVER_VERSION=1.0.0
REYTECH_URL=https://your-app.railway.app
BASE_URL=https://your-app.railway.app

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
GMAIL_ADDRESS=rfq@reytechinc.com
GMAIL_PASSWORD=
ENABLE_EMAIL_POLLING=true

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
NOTIFY_PHONE=+1xxxxxxxxxx

# ── Webhooks (n8n/Zapier) ────────────────────────────────────────────────────
WEBHOOK_RFQ_CREATED_URL=https://your-n8n-instance/webhook/rfq-created
WEBHOOK_ORDER_UPDATED_URL=
WEBHOOK_SECRET=

# ── QuickBooks ────────────────────────────────────────────────────────────────
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REFRESH_TOKEN=
QB_REALM_ID=
QB_SANDBOX=false

# ── AI / Research ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
SERPAPI_KEY=
