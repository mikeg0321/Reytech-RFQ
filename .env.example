# Reytech RFQ — Environment Variables
# Copy to .env and fill in values (or set in Railway dashboard)

# ── Required ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-flask-secret-key
DASH_USER=reytech
DASH_PASS=your-dashboard-password

# ── API Key (for MCP, webhooks, service-to-service) ──────────────────────────
API_KEY=your-secret-key-here

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_SERVER_NAME=reytech-rfq
MCP_SERVER_VERSION=1.0.0
REYTECH_URL=https://your-app.railway.app
BASE_URL=https://your-app.railway.app

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
GMAIL_ADDRESS=rfq@reytechinc.com
GMAIL_PASSWORD=
ENABLE_EMAIL_POLLING=true

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
NOTIFY_PHONE=+1xxxxxxxxxx

# ── Webhooks (n8n/Zapier) ────────────────────────────────────────────────────
WEBHOOK_RFQ_CREATED_URL=https://your-n8n-instance/webhook/rfq-created
WEBHOOK_ORDER_UPDATED_URL=
WEBHOOK_SECRET=

# ── QuickBooks ────────────────────────────────────────────────────────────────
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REFRESH_TOKEN=
QB_REALM_ID=
QB_SANDBOX=false

# ── AI / Research ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
SERPAPI_KEY=

# ── Google Drive Backup (optional — enables nightly backup to Drive) ─────────
GOOGLE_DRIVE_CREDENTIALS=  # base64-encoded service account JSON
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ── Second Gmail Inbox (optional — Mike's personal inbox for monitoring) ─────
GMAIL_ADDRESS_2=
GMAIL_PASSWORD_2=
GMAIL_APP_PASSWORD=  # app-specific password (if different from GMAIL_PASSWORD)

# ── Background Agents ────────────────────────────────────────────────────────
ENABLE_BACKGROUND_AGENTS=true  # master switch for all daemon threads

# ── SCPRS (State Contract Procurement) ───────────────────────────────────────
SCPRS_USERNAME=
SCPRS_PASSWORD=

# ── Voice (Vapi / ElevenLabs) ────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=  # required for /api/voice/webhook to accept requests
OPENAI_API_KEY=  # used by Vapi for LLM

# ── SCPRS Scraper Service (Playwright extraction) ────────────────────────────
SCRAPER_SERVICE_URL=  # e.g. http://scprs-scraper.railway.internal:8001
SCRAPER_SECRET=  # shared secret for scraper auth

# ── Notifications / Integrations ─────────────────────────────────────────────
SLACK_WEBHOOK_URL=
GROWTH_WEBHOOK_URL=
GROWTH_ENCRYPT_KEY=  # encryption key for growth agent data (required, no fallback)

# ── Data Directory Override (optional) ───────────────────────────────────────
# REYTECH_DATA_DIR=/data  # auto-detected on Railway; set for local dev
# DATA_DIR=/data  # alternative name (routes_v1.py)
